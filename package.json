{
  "name": "islandflow",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:infra": "docker compose up",
    "dev:infra:down": "docker compose down",
    "dev:desktop": "bun run scripts/dev-desktop.ts",
    "dev:desktop:remote": "bun run scripts/dev-desktop.ts --remote",
    "dev:web": "bun --cwd=apps/web run dev",
    "dev:services": "bun run scripts/dev-services.ts",
    "package:desktop": "bun --cwd=apps/desktop run package",
    "make:desktop": "bun --cwd=apps/desktop run make",
    "deploy": "bun run scripts/deploy.ts",
    "deploy:main": "./deploy main",
    "deploy:current-branch": "./deploy current-branch",
    "typecheck": "bun run scripts/typecheck.ts",
    "check:public-api-routes": "bun run scripts/check-public-api-routes.ts",
    "sync:docker-workspace": "bun run scripts/sync-docker-workspace.ts",
    "check:docker-workspace": "bun run scripts/check-docker-workspace.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.1.3"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "tar": "^7.5.15",
    "tmp": "^0.2.5"
  },
  "dependencies": {
    "@pierre/diffs": "^1.2.2"
  }
}
